{
  "name": "recruitment-ai-mcp",
  "description": "> Hiring automation tools - job descriptions, CV scoring, interview questions, salary benchmarks, offer letters",
  "version": "1.0.0",
  "tools": [
    {
      "name": "generate_job_description",
      "description": "Generate a professional job description.",
      "parameters": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "department": {
            "type": "string"
          },
          "level": {
            "type": "string"
          },
          "skills": {
            "type": "string"
          },
          "company_name": {
            "type": "string"
          },
          "remote": {
            "type": "boolean"
          },
          "key_responsibilities": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "department"
        ]
      }
    },
    {
      "name": "score_cv",
      "description": "Score and analyze a CV/resume against job requirements.",
      "parameters": {
        "type": "object",
        "properties": {
          "cv_text": {
            "type": "string"
          },
          "required_skills": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "preferred_skills": {
            "type": "string"
          },
          "min_years_experience": {
            "type": "integer"
          },
          "required_education": {
            "type": "string"
          }
        },
        "required": [
          "cv_text",
          "required_skills"
        ]
      }
    },
    {
      "name": "generate_interview_questions",
      "description": "Generate tailored interview questions for a role.",
      "parameters": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string"
          },
          "level": {
            "type": "string"
          },
          "categories": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "skills_to_probe": {
            "type": "string"
          }
        },
        "required": [
          "role"
        ]
      }
    },
    {
      "name": "benchmark_salary",
      "description": "Get salary benchmarks for a role by level and location.",
      "parameters": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string"
          },
          "level": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "currency": {
            "type": "string"
          }
        },
        "required": [
          "role"
        ]
      }
    },
    {
      "name": "draft_offer_letter",
      "description": "Draft a professional offer letter for a candidate.",
      "parameters": {
        "type": "object",
        "properties": {
          "candidate_name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "salary": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          },
          "start_date": {
            "type": "string"
          },
          "company_name": {
            "type": "string"
          },
          "benefits": {
            "type": "string"
          },
          "probation_months": {
            "type": "integer"
          },
          "notice_period_weeks": {
            "type": "integer"
          },
          "annual_leave_days": {
            "type": "integer"
          },
          "reporting_to": {
            "type": "string"
          }
        },
        "required": [
          "candidate_name",
          "role",
          "salary"
        ]
      }
    }
  ]
}
